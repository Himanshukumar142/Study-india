# ── JEE/NEET Platform - Centralized Environment Variables ──

# Node Environment
NODE_ENV=production

# Client URL (Used by Nginx/CORS, e.g. http://yourdomain.com or local)
CLIENT_URL=http://localhost

# Database Connections (Cloud Atlas or local mongodb container)
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/jee-neet?retryWrites=true&w=majority

# JWT Token Secrets
JWT_ACCESS_SECRET=your_super_secret_access_key_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Backblaze B2 Object Storage (For content uploads/revision materials)
B2_KEY_ID=your_backblaze_key_id
B2_APPLICATION_KEY=your_backblaze_application_key
B2_BUCKET_NAME=your_bucket_name
B2_BUCKET_ID=your_bucket_id
B2_DOWNLOAD_URL=https://f004.backblazeb2.com

# Google Gemini AI API Key (For flashcard generation and doubt solving bot)
GEMINI_API_KEY=your_google_gemini_api_key_here

# ── System Usage Limits (Storage monitor) ──
MONGODB_FREE_LIMIT_MB=512
B2_FREE_LIMIT_GB=10

# ── Microservice Internal Network Endpoints (Docker Compose Default) ──
AUTH_SERVICE_URL=http://auth-service:5001
USER_SERVICE_URL=http://user-service:5002
CONTENT_SERVICE_URL=http://content-service:5003
